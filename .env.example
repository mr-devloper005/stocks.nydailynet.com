NEXT_PUBLIC_MASTER_PANEL_URL=https://masterpanel.seoparadox.com
NEXT_PUBLIC_MASTER_API_URL=https://masterpanel.seoparadox.com
NEXT_PUBLIC_SITE_CODE=4dn0v9nt6q
NEXT_PUBLIC_FEED_REVALIDATE_SECONDS=300

NEXT_PUBLIC_SITE_NAME=Stocks Nydailynet
NEXT_PUBLIC_SITE_TAGLINE=Independent media updates
NEXT_PUBLIC_SITE_DESCRIPTION=A media-distribution newsroom for announcements, coverage, and press updates on Stocks Nydailynet.
NEXT_PUBLIC_SITE_DOMAIN=stocks.nydailynet.com
NEXT_PUBLIC_SITE_URL=https://stocks.nydailynet.com
NEXT_PUBLIC_SITE_OG_IMAGE=/og-default.png
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# Home latest releases feed control
# Comma-separated task keys used by the homepage latest releases section.
# Allowed values: mediaDistribution,article,listing,classified,image,profile,social,pdf,org,sbm,comment
NEXT_PUBLIC_HOME_RELEASE_TASKS=mediaDistribution,article
# Total number of posts to render in that section (range: 4-40)
NEXT_PUBLIC_HOME_RELEASE_LIMIT=16

# News page feed control (/news)
# Comma-separated task keys to include on the news archive page.
NEXT_PUBLIC_NEWS_PAGE_TASKS=mediaDistribution,article
# How many posts to fetch per task before merge/dedup.
NEXT_PUBLIC_NEWS_PAGE_LIMIT_PER_TASK=30
